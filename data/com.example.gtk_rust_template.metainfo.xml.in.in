<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>@app-id@</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <name>Gtk Rust Template</name>
  <summary>A GNOME/GTK application template written in Rust</summary>
  <description>
    <p>
      This is a template application for creating GNOME/GTK applications using Rust.
    </p>
  </description>
  <url type="homepage">https://github.com/example/gtk-rust-template</url>
  <url type="bugtracker">https://github.com/example/gtk-rust-template/issues</url>
  <content_rating type="oars-1.1"/>
  <translation type="gettext">gtk-rust-template</translation>
  <launchable type="desktop-id">@app-id@.desktop</launchable>
</component>
